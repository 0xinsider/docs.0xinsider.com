{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "0xinsider API",
  "colors": {
    "primary": "#000000",
    "light": "#000000",
    "dark": "#ffffff"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "rate-limits",
              "errors"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/grades",
              "concepts/pagination",
              "concepts/number-formatting"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "mcp"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Traders",
            "pages": [
              "api-reference/endpoint/get-trader",
              "api-reference/endpoint/get-leaderboard"
            ]
          },
          {
            "group": "Markets",
            "pages": [
              "api-reference/endpoint/search-markets",
              "api-reference/endpoint/explore-markets",
              "api-reference/endpoint/get-market-intel"
            ]
          },
          {
            "group": "Whale Trades",
            "pages": [
              "api-reference/endpoint/get-whale-trades"
            ]
          },
          {
            "group": "Insider Radar",
            "pages": [
              "api-reference/endpoint/get-insider-radar"
            ]
          },
          {
            "group": "System",
            "pages": [
              "api-reference/endpoint/health"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Terminal",
          "href": "https://0xinsider.com",
          "icon": "chart-line"
        },
        {
          "anchor": "Changelog",
          "href": "https://0xinsider.com/changelog",
          "icon": "list"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@0xinsider.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://0xinsider.com/developers"
    }
  },
  "api": {
    "baseUrl": "https://api.0xinsider.com",
    "auth": {
      "method": "bearer"
    },
    "openapi": "api-reference/openapi.json"
  },
  "chat": {
    "enabled": false
  },
  "footer": {
    "socials": {
      "x": "https://x.com/0xinsiderdotcom",
      "github": "https://github.com/0xinsider",
      "linkedin": "https://linkedin.com/company/0xinsider-com"
    }
  }
}
